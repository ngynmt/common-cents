# Upstash Redis — for engagement counters (support/oppose/contacted)
# Sign up free at https://upstash.com and create a Redis database.
# Without these, the app falls back to in-memory counters (resets on restart).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Geocodio — for ZIP-to-representative lookup (ZIP → congressional district → legislators)
# Sign up free at https://www.geocod.io (2,500 free lookups/day)
# Without this, falls back to sample representative data.
GEOCODIO_API_KEY=

# Congress.gov API — for live bill tracking and vote records
# Sign up free at https://api.congress.gov/sign-up/ (instant, no approval needed)
# Without this, falls back to DEMO_KEY which has stricter rate limits.
CONGRESS_API_KEY=

# FEC API — for campaign finance data (Follow the Money feature)
# Sign up free at https://api.data.gov/signup/ (instant API key, 1000 req/hr)
# Without this, falls back to DEMO_KEY which has stricter rate limits.
FEC_API_KEY=
