# Upstash Redis — for engagement counters (support/oppose/contacted)
# Sign up free at https://upstash.com and create a Redis database.
# Without these, the app falls back to in-memory counters (resets on restart).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google Civic Information API — for live representative lookup by ZIP/address
# Get a key at https://console.cloud.google.com (enable "Google Civic Information API")
# Without this, the app falls back to sample representative data.
GOOGLE_CIVIC_API_KEY=

# Congress.gov API — for live bill tracking and member details
# Sign up free at https://api.congress.gov/sign-up/ (instant, no approval needed)
# Without this, falls back to DEMO_KEY which has stricter rate limits.
CONGRESS_API_KEY=

# Future: API keys for live data
# PROPUBLICA_API_KEY=
